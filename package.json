{
  "name": "copilot-plus",
  "displayName": "Copilot Plus",
  "description": "Cursor-style agent-driven AI coding for enterprise teams using GitHub Copilot via vscode.lm",
  "version": "0.1.0",
  "publisher": "copilot-plus",
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n/bundle.l10n.json",
  "contributes": {
    "commands": [
      {
        "command": "copilotPlus.openWorkspace",
        "title": "Copilot Plus: Open Workspace",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.inlineEdit",
        "title": "Copilot Plus: Inline Edit",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.knowledge.init",
        "title": "Copilot Plus: Initialize AGENTS.md",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.docs.compact",
        "title": "Copilot Plus: Compact Document Tree",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.docs.markReviewed",
        "title": "Copilot Plus: Mark Document Reviewed",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.docs.assignOrphan",
        "title": "Copilot Plus: Assign Orphan Code",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.openDecisionCenter",
        "title": "Copilot Plus: Open Decision Center",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.build.start",
        "title": "Copilot Plus: Start Build",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.build.stop",
        "title": "Copilot Plus: Stop Build",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.index.rebuild",
        "title": "Copilot Plus: Rebuild Index",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.deploy.generateManifest",
        "title": "Copilot Plus: Generate Deploy Manifest",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.deploy.applyManifest",
        "title": "Copilot Plus: Apply Deploy Manifest",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.skills.create",
        "title": "Copilot Plus: Create Skill",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.composer.submit",
        "title": "Copilot Plus: Run Composer",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.composer.attachFiles",
        "title": "Copilot Plus: Composer Attach Files",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.composer.cancel",
        "title": "Copilot Plus: Cancel Composer",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.cli",
        "title": "Copilot Plus: CLI",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.design.continue",
        "title": "Copilot Plus: Continue Design Step",
        "category": "Copilot Plus"
      },
      {
        "command": "copilotPlus.design.pickStep",
        "title": "Copilot Plus: Pick Design Step",
        "category": "Copilot Plus"
      }
    ],
    "keybindings": [
      {
        "command": "copilotPlus.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus && !editorReadonly && !inQuickInput"
      },
      {
        "command": "copilotPlus.focusTaskPanel",
        "key": "ctrl+alt+1",
        "when": "copilotPlus.workspaceOpen"
      },
      {
        "command": "copilotPlus.focusArchitecturePanel",
        "key": "ctrl+alt+2",
        "when": "copilotPlus.workspaceOpen"
      },
      {
        "command": "copilotPlus.focusRequirementPanel",
        "key": "ctrl+alt+3",
        "when": "copilotPlus.workspaceOpen"
      },
      {
        "command": "copilotPlus.focusCommitPanel",
        "key": "ctrl+alt+4",
        "when": "copilotPlus.workspaceOpen"
      },
      {
        "command": "copilotPlus.focusDeployPanel",
        "key": "ctrl+alt+5",
        "when": "copilotPlus.workspaceOpen"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotPlus",
          "title": "Copilot Plus",
          "icon": "resources/icons/copilot-plus.svg"
        }
      ]
    },
    "views": {
      "copilotPlus": [
        {
          "id": "copilotPlus.controlConsole",
          "name": "Control Console",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "copilotPlus.controlConsole",
        "contents": "Copilot Plus is ready.\n[Open Workspace](command:copilotPlus.openWorkspace)\n[Open Settings](command:copilotPlus.openSettings)"
      }
    ],
    "configuration": {
      "title": "Copilot Plus",
      "properties": {
        "copilotPlus.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Copilot Plus telemetry (content-free events only)"
        },
        "copilotPlus.tabCompletion.mode": {
          "type": "string",
          "enum": [
            "disabled",
            "delegate_to_copilot",
            "own"
          ],
          "default": "delegate_to_copilot"
        },
        "copilotPlus.nes.mode": {
          "type": "string",
          "enum": [
            "disabled",
            "delegate_to_copilot"
          ],
          "default": "delegate_to_copilot"
        },
        "copilotPlus.rag.enabled": {
          "type": "boolean",
          "default": true
        },
        "copilotPlus.indexing.embeddingMode": {
          "type": "string",
          "enum": [
            "proposed_lm",
            "local",
            "sparse_only",
            "auto"
          ],
          "default": "auto"
        },
        "copilotPlus.indexing.respectGitignore": {
          "type": "boolean",
          "default": true
        },
        "copilotPlus.indexing.embeddingAddon.url": {
          "type": "string",
          "default": ""
        },
        "copilotPlus.indexing.embeddingAddon.sha256": {
          "type": "string",
          "default": ""
        },
        "copilotPlus.knowledge.selfReflection.enabled": {
          "type": "boolean",
          "default": true
        },
        "copilotPlus.knowledge.selfReflection.minBuildTasks": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 50
        },
        "copilotPlus.context.summarization.mode": {
          "type": "string",
          "enum": [
            "auto",
            "manual",
            "disabled"
          ],
          "default": "auto"
        },
        "copilotPlus.context.summarization.keepLastTurns": {
          "type": "number",
          "default": 6,
          "minimum": 2,
          "maximum": 20
        },
        "copilotPlus.context.tierOverride": {
          "type": "string",
          "enum": [
            "auto",
            "s",
            "m",
            "l"
          ],
          "default": "auto"
        },
        "copilotPlus.docs.staleThresholdDays": {
          "type": "number",
          "default": 90,
          "minimum": 30,
          "maximum": 365
        },
        "copilotPlus.deploy.mode": {
          "type": "string",
          "enum": [
            "Manual",
            "Auto"
          ],
          "default": "Manual"
        },
        "copilotPlus.cache.enabled": {
          "type": "boolean",
          "default": true
        },
        "copilotPlus.speculative.enabled": {
          "type": "boolean",
          "default": true
        },
        "copilotPlus.speculative.maxConcurrent": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 4
        },
        "copilotPlus.tabCompletion.enabledLanguages": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "copilotPlus.tabCompletion.triggerDelayMs": {
          "type": "number",
          "default": 75,
          "minimum": 0,
          "maximum": 2000
        },
        "copilotPlus.tabCompletion.timeoutMs": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "maximum": 10000
        },
        "copilotPlus.nes.maxChain": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50
        },
        "copilotPlus.workflow.autonomyLevel": {
          "type": "string",
          "enum": [
            "Manual",
            "Approve_Edits",
            "Approve_Commands",
            "Full_Auto"
          ],
          "default": "Manual"
        },
        "copilotPlus.workflow.commandDenyList": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "copilotPlus.workflow.maxConcurrentTasks": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 8
        },
        "copilotPlus.sensitiveFilePatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "copilotPlus.checkpoints.retentionCount": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 1000
        },
        "copilotPlus.session.tokenCap": {
          "type": "number",
          "default": 100000,
          "minimum": 1000,
          "maximum": 1000000
        },
        "copilotPlus.tools.permissions": {
          "type": "object",
          "default": {}
        },
        "copilotPlus.decisions.timeoutSec": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "maximum": 1800
        },
        "copilotPlus.models.default": {
          "type": "string",
          "default": ""
        },
        "copilotPlus.models.defaults": {
          "type": "object",
          "default": {}
        },
        "copilotPlus.verification.Architect": {
          "type": "object",
          "default": {
            "enabled": false,
            "candidates": 3,
            "strategy": "majority_vote",
            "disagreementMax": 0
          },
          "properties": {
            "enabled": { "type": "boolean" },
            "candidates": { "type": "number", "minimum": 1, "maximum": 5 },
            "strategy": {
              "type": "string",
              "enum": ["majority_vote", "arbiter", "union"]
            },
            "disagreementMax": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "copilotPlus.verification.Designer": {
          "type": "object",
          "default": {
            "enabled": false,
            "candidates": 3,
            "strategy": "majority_vote",
            "disagreementMax": 0
          }
        },
        "copilotPlus.verification.Reviewer": {
          "type": "object",
          "default": {
            "enabled": false,
            "candidates": 3,
            "strategy": "majority_vote",
            "disagreementMax": 0
          }
        },
        "copilotPlus.verification.Deployer": {
          "type": "object",
          "default": {
            "enabled": false,
            "candidates": 3,
            "strategy": "majority_vote",
            "disagreementMax": 0.6
          }
        },
        "copilotPlus.background.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Run background tasks while VS Code is open and you are idle (R-AG-9)"
        },
        "copilotPlus.background.idleThreshold": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "maximum": 3600,
          "description": "Seconds of editor/conversation inactivity before background tasks start"
        },
        "copilotPlus.background.tasks": {
          "type": "array",
          "default": [
            "doc_drift_scan",
            "index_rebuild",
            "dependency_audit"
          ],
          "items": {
            "type": "string",
            "enum": [
              "doc_drift_scan",
              "flaky_test_scan",
              "dead_code_scan",
              "dependency_audit",
              "agents_md_proposal",
              "lateral_link_proposal",
              "index_rebuild"
            ]
          },
          "description": "Enabled background task identifiers"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js && npm run compile:webview",
    "compile:webview": "vite build --config webview-ui/vite.config.ts && vite build --config webview-ui/vite.tab.config.ts && node scripts/copy-webview-assets.mjs",
    "watch": "node esbuild.js --watch",
    "test:unit": "tsc -p tsconfig.test.json && node --test dist-test/test/unit/**/*.test.js",
    "verify:ci-headless": "tsc -p tsconfig.test.json && node scripts/verify-ci-headless.mjs",
    "verify:onnx-addon": "tsc -p tsconfig.test.json && node scripts/verify-onnx-addon.mjs",
    "verify:i18n-a11y": "node scripts/audit-i18n-a11y.mjs",
    "test": "npm run test:unit && npm run verify:ci-headless && npm run verify:onnx-addon && npm run verify:i18n-a11y",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.109.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^2.24.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "esbuild": "^0.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
